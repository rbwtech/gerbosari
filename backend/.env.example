DATABASE_URL=mysql://root:password@localhost:3306/gerbosari
BIND_ADDR=0.0.0.0:3000
CORS_ORIGIN=http://localhost:5173
RUST_LOG=info,sqlx=warn
APP_ENV=development

# --- Auth ---
# Generate a 32+ byte secret with: openssl rand -hex 32
JWT_SECRET=change_me_with_openssl_rand_hex_32
# Optional. Default: 24
JWT_EXPIRY_HOURS=24
# Admin bootstrap. Credential never lives in the repo — set ADMIN_PASSWORD
# in the local .env on first boot. Backend bcrypts + upserts the admin row,
# then this can be cleared. The row persists in MySQL across deploys.
# Setting ADMIN_PASSWORD again on a later boot rotates the stored hash.
ADMIN_USERNAME=adminrafli
ADMIN_PASSWORD=
