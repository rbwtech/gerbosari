DATABASE_URL=mysql://root:password@localhost:3306/gerbosari
BIND_ADDR=0.0.0.0:3000
CORS_ORIGIN=http://localhost:5173
RUST_LOG=info,sqlx=warn
APP_ENV=development

# --- Auth ---
# Generate a 32+ byte secret with: openssl rand -hex 32
JWT_SECRET=change_me_with_openssl_rand_hex_32
# Optional. Default: 24
JWT_EXPIRY_HOURS=24
#   - Leave ADMIN_PASSWORD empty: backend verifies the migration-seeded row
#     exists and serves normally (default flow).
#   - Set ADMIN_PASSWORD to rotate: backend upserts the bcrypt hash on next
#     boot, overwriting the migration-seeded credential.
ADMIN_USERNAME=
ADMIN_PASSWORD=
