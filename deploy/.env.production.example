# /www/wwwroot/gerbosari.rbwtech.io/_backend/.env — production template.
# Install with: sudo install -m 0600 -o www -g www this-file \
#               /www/wwwroot/gerbosari.rbwtech.io/_backend/.env
# Never commit the populated file.

# --- Database ---
# aaPanel-managed MySQL (same host) (MySQL 9). Create the db + user via the panel UI:
#   Database name: gerbosari
#   Username:      gerbosari
#   Host:          127.0.0.1 (or %)
DATABASE_URL=mysql://gerbosari:CHANGE_ME_STRONG_PASS@127.0.0.1:3306/gerbosari

# --- HTTP server ---
# Bind localhost only; aaPanel nginx reverse-proxies /api/* to here.
BIND_ADDR=127.0.0.1:3000

# --- App mode ---
APP_ENV=production

# --- Logging ---
# error | warn | info | debug | trace
RUST_LOG=info,sqlx=warn

# --- CORS ---
# Public origin(s). Comma-separated if more than one.
CORS_ORIGIN=https://gerbosari.rbwtech.io

# Images are served directly by nginx (alias /images/ ->
# /www/wwwroot/gerbosari.rbwtech.io/content/images/). The backend does not
# read any image path env var; galeri rows store URL paths only.

# --- Auth ---
# JWT signing key. MUST be at least 32 bytes — the backend refuses to boot
# otherwise. Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_RUN_openssl_rand_hex_32
# Optional. Default: 24
JWT_EXPIRY_HOURS=24
# Admin bootstrap. Credential is NEVER committed to the repo — it lives only
# in this file on the production host (mode 0600, owner www).
#
# First deploy:
#   ADMIN_USERNAME=admin
#   ADMIN_PASSWORD=<plaintext>     <- set this, restart backend.
#   Backend bcrypts + upserts the admin row, then logs "admin bootstrapped".
#
# Subsequent deploys:
#   Clear ADMIN_PASSWORD (leave empty). The admin row persists in MySQL;
#   backend only verifies it exists at boot. Re-setting ADMIN_PASSWORD on a
#   later boot rotates the stored hash.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
